# Copy this file to .env and fill in your values
# .env is gitignored and should never be committed

POSTGRES_USER=databridge
POSTGRES_PASSWORD=changeme
POSTGRES_DB=databridge

DATABASE_URL=postgresql://databridge:changeme@db/databridge

# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

REDIS_URL=redis://redis:6379/0

AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# LocalStack — leave blank for community edition, add token for pro features
LOCALSTACK_AUTH_TOKEN=your_token_here

# S3 — override these to point at real AWS in production (leave as-is for LocalStack dev)
AWS_ENDPOINT_URL=http://localstack:4566
S3_PUBLIC_URL=http://localhost:4566
